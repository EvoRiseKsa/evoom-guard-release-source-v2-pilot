{
  "policy_id": "release-source-admission-v2-pilot",
  "policy_version": "1",
  "protected": [
    ".github/workflows/*",
    ".github/CODEOWNERS",
    ".evoguard.json",
    "LICENSE",
    "pytest.ini",
    "docs/*",
    "security/release-source-pack/*",
    "security/*.lock",
    "tests/*",
    "tools/*",
    "trust/*"
  ],
  "allow": [],
  "allow_new_tests": false,
  "verifier_pack": "security/release-source-pack",
  "expect_verifier_pack_sha256": "1069166cacc8e885bfe128b4767888f5fbdba66d53d881bd30fe2b55ff789e5b",
  "blackbox": true,
  "blackbox_only": true,
  "isolation": "docker",
  "docker_image": "python:3.12-slim@sha256:57cd7c3a7a273101a6485ba99423ee568157882804b1124b4dd04266317710de",
  "docker_network": "none",
  "require_report_integrity": "external_process_isolated",
  "require_candidate_isolation": "docker",
  "timeout": 120
}
